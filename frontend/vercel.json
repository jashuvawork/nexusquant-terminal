{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.nexusquant.uk/api/:path*" },
    { "source": "/ws/:path*", "destination": "https://api.nexusquant.uk/ws/:path*" },
    { "source": "/health", "destination": "https://api.nexusquant.uk/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
