ENVIRONMENT=production
CORS_ORIGINS=https://nexusquant-terminal.vercel.app,http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nexusquant
REDIS_URL=redis://redis:6379/0
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://your-render-api.onrender.com/api/upstox/callback
UPSTOX_ACCESS_TOKEN=
UPSTOX_TOKEN_FILE=/opt/nexusquant/upstox_token.json
AI_SCORE_THRESHOLD=76
SAFE_MODE_THRESHOLD=86
MAX_EXPOSURE_PCT=100
DAILY_DRAWDOWN_PCT=3
PRIMARY_SYMBOL=NIFTY
NIFTY_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
SENSEX_INSTRUMENT_KEY=BSE_INDEX|SENSEX
NIFTY_EXPIRY_DATE=2026-06-04
SENSEX_EXPIRY_DATE=2026-06-05
ENABLE_LIVE_TRADING=false
AGGRESSIVE_MODE=false
AGGRESSION_PROFILE=realistic_aggressive
TRADING_CAPITAL_DEFAULT=500000
MARKET_POLL_SECONDS=5
PAPER_TRADING=true
AI_LEARNING_ENABLED=true
AI_STATE_FILE=/opt/nexusquant/ai_state.json
PAPER_TARGET_POINTS=15
PAPER_STOP_POINTS=7
PAPER_BREAKEVEN_SHIFT_POINTS=8
MAX_PAPER_TRADE_SECONDS=240
PAPER_DUPLICATE_SIGNAL_COOLDOWN_SECONDS=180
OPTION_BROKERAGE_PER_ORDER=20
OPTION_STT_SELL_PCT=0.0625
OPTION_EXCHANGE_TXN_PCT=0.03503
OPTION_SEBI_PCT=0.0001
OPTION_STAMP_BUY_PCT=0.003
OPTION_GST_PCT=18
MIN_REQUIRED_MOVE_POINTS=5
PROFIT_TARGET_PRIMARY_PCT=33
PROFIT_TARGET_SECONDARY_PCT=22
PROFIT_TARGET_FALLBACK_PCT=11
PROFIT_LOCK_RETAIN_PCT=100
HISTORICAL_TRAINING_TARGET_TRADES=1000
NIFTY_OPT_MIN_TQS=72
NIFTY_OPT_BREAKOUT_ATR=0.35
NIFTY_OPT_VOLUME_MULTIPLIER=2.0
NIFTY_OPT_TARGET_POINTS=15
NIFTY_OPT_STOP_POINTS=7
NIFTY_OPT_TRAIL_ATR=0.65
NIFTY_OPT_ENTRY_MODEL=breakout
SENSEX_OPT_MIN_TQS=68
SENSEX_OPT_BREAKOUT_ATR=0.35
SENSEX_OPT_VOLUME_MULTIPLIER=1.3
SENSEX_OPT_TARGET_POINTS=20
SENSEX_OPT_STOP_POINTS=10
SENSEX_OPT_TRAIL_ATR=0.7
SENSEX_OPT_ENTRY_MODEL=breakout
SHADOW_TRADE_ALL_SIGNALS=false
PAPER_TRADING_RESPECTS_STOP=false
OPTION_PREMIUM_HISTORY_AVAILABLE=true
EXPLOSIVE_RUNNER_ENABLED=true
EXPLOSIVE_RUNNER_SCAN_STRIKES=16
EXPLOSIVE_RUNNER_MIN_SCORE=55
EXPLOSIVE_RUNNER_PREMIUM_MIN=25
EXPLOSIVE_RUNNER_PREMIUM_MAX=250
BACKGROUND_MARKET_MONITOR_ENABLED=true
NEWS_PROVIDER=finnhub
UPSTOX_NEWS_ENABLED=false
FINNHUB_API_KEY=
NEWS_LOOKBACK_ITEMS=20
NEWS_CACHE_TTL_SECONDS=300
NEWS_TIMEOUT_SECONDS=3
SNAPSHOT_CACHE_SECONDS=5
ACCOUNT_SNAPSHOT_CACHE_SECONDS=30
EXPIRY_CACHE_SECONDS=3600
MARKET_SNAPSHOT_INSTRUMENT_KEYS=NSE_INDEX|Nifty 50,BSE_INDEX|SENSEX
MARKET_SNAPSHOT_MONITOR_ENABLED=true
MARKET_SNAPSHOT_POLL_SECONDS=60
