ENVIRONMENT=production
CORS_ORIGINS=https://your-vercel-domain.vercel.app,http://localhost:5173
DATABASE_URL=postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/nexusquant
REDIS_URL=redis://ELASTICACHE_ENDPOINT:6379/0
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://api.yourdomain.com/api/upstox/callback
UPSTOX_ACCESS_TOKEN=
UPSTOX_TOKEN_FILE=/opt/nexusquant/upstox_token.json
PRIMARY_SYMBOL=NIFTY
NIFTY_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
SENSEX_INSTRUMENT_KEY=BSE_INDEX|SENSEX
NIFTY_EXPIRY_DATE=
SENSEX_EXPIRY_DATE=
ENABLE_LIVE_TRADING=false
PAPER_TRADING=true
PAPER_SESSION_ADJUSTMENTS_ENABLED=true
PAPER_ALWAYS_TRADE_EXPLOSIVE_RUNNERS=true
PAPER_MIN_HOLD_BEFORE_CHOP_EXIT_SECONDS=45
AI_LEARNING_ENABLED=true
AI_STATE_FILE=/opt/nexusquant/ai_state.json
PAPER_REPLAY_FILE=/opt/nexusquant/paper_replay.jsonl
PAPER_REPLAY_PERSIST_LIMIT=20000
PAPER_SESSIONS_FILE=/opt/nexusquant/paper_sessions.jsonl
PAPER_SESSIONS_PERSIST_LIMIT=2000
PAPER_TRADES_FILE=/opt/nexusquant/paper_trades.json
PAPER_TRADES_PERSIST_LIMIT=2000
PAPER_SESSION_ROTATION_ENABLED=true
SHADOW_TRADE_ALL_SIGNALS=false
PAPER_TRADING_RESPECTS_STOP=false
PAPER_TRADE_ALLOCATION_PCT=12
PAPER_MIN_TRADE_ALLOCATION_PCT=8
PAPER_MAX_DAILY_LOSS_PCT=6
PAPER_MAX_DAILY_LOSS_AMOUNT=30000
PAPER_MAX_CONSECUTIVE_LOSSES=8
PAPER_DAILY_PROFIT_STOP_PCT=18
PROFIT_TARGET_FALLBACK_PCT=6
PROFIT_TARGET_SECONDARY_PCT=12
PROFIT_TARGET_PRIMARY_PCT=18
OPEN_DRIVE_PROFIT_TARGET_FALLBACK_PCT=11
OPEN_DRIVE_PROFIT_TARGET_SECONDARY_PCT=22
OPEN_DRIVE_PROFIT_TARGET_PRIMARY_PCT=33
OPEN_DRIVE_PROFIT_STOP_PCT=33
OPEN_DRIVE_ALLOCATION_MULTIPLIER=1.85
PAPER_TARGET_POINTS=12
PAPER_STOP_POINTS=6
PAPER_BREAKEVEN_SHIFT_POINTS=6
MAX_PAPER_TRADE_SECONDS=180
PAPER_DUPLICATE_SIGNAL_COOLDOWN_SECONDS=300
AGGRESSION_PROFILE=balanced_pro
AI_SCORE_THRESHOLD=82
NIFTY_OPT_MIN_TQS=78
SENSEX_OPT_MIN_TQS=74
EXPLOSIVE_RUNNER_MIN_SCORE=85
EXPLOSIVE_RUNNER_MOMENTUM_MIN_SCORE=72
EXPLOSIVE_RUNNER_MOMENTUM_PREMIUM_VELOCITY_PCT=5
OPTION_BROKERAGE_PER_ORDER=20
OPTION_STT_SELL_PCT=0.0625
OPTION_EXCHANGE_TXN_PCT=0.03503
OPTION_SEBI_PCT=0.0001
OPTION_STAMP_BUY_PCT=0.003
OPTION_GST_PCT=18
AGGRESSIVE_MODE=false
TRADING_CAPITAL_DEFAULT=500000
MAX_EXPOSURE_PCT=100
NIFTY_OPT_TARGET_POINTS=15
NIFTY_OPT_STOP_POINTS=7
NIFTY_OPT_TRAIL_ATR=0.65
SENSEX_OPT_TARGET_POINTS=20
SENSEX_OPT_STOP_POINTS=10
SENSEX_OPT_TRAIL_ATR=0.7
EXPLOSIVE_RUNNER_SCAN_STRIKES=16
EXPLOSIVE_RUNNER_PREMIUM_MIN=25
EXPLOSIVE_RUNNER_PREMIUM_MAX=250
MARKET_POLL_SECONDS=5
MARKET_SNAPSHOT_POLL_SECONDS=60
NEWS_CACHE_TTL_SECONDS=300
NEWS_TIMEOUT_SECONDS=3
