ENVIRONMENT=production
CORS_ORIGINS=https://your-vercel-domain.vercel.app,http://localhost:5173
DATABASE_URL=postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/nexusquant
REDIS_URL=redis://ELASTICACHE_ENDPOINT:6379/0
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://api.yourdomain.com/api/upstox/callback
UPSTOX_ACCESS_TOKEN=
UPSTOX_TOKEN_FILE=/opt/nexusquant/upstox_token.json
PRIMARY_SYMBOL=NIFTY
NIFTY_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
SENSEX_INSTRUMENT_KEY=BSE_INDEX|SENSEX
NIFTY_EXPIRY_DATE=
SENSEX_EXPIRY_DATE=
ENABLE_LIVE_TRADING=false
PAPER_TRADING=true
SHADOW_TRADE_ALL_SIGNALS=true
PAPER_TRADING_RESPECTS_STOP=false
AGGRESSIVE_MODE=false
AGGRESSION_PROFILE=realistic_aggressive
TRADING_CAPITAL_DEFAULT=100000
EXPLOSIVE_RUNNER_SCAN_STRIKES=16
EXPLOSIVE_RUNNER_PREMIUM_MIN=25
EXPLOSIVE_RUNNER_PREMIUM_MAX=250
MARKET_POLL_SECONDS=5
MARKET_SNAPSHOT_POLL_SECONDS=15
NEWS_PROVIDER=upstox
FINNHUB_API_KEY=
OPTION_PREMIUM_HISTORY_AVAILABLE=true
