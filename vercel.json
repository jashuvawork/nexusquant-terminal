{
  "buildCommand": "npm --prefix frontend install && npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://nexusquant-alb-27974946.ap-south-1.elb.amazonaws.com/api/:path*" },
    { "source": "/health", "destination": "http://nexusquant-alb-27974946.ap-south-1.elb.amazonaws.com/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
